---
import BaseLayout from "../layouts/BaseLayout.astro";
import { TIENDA, HILOS, PRODUCTOS } from "../data/tienda.js";
import type { ImageMetadata } from "astro";

/* ================================================================
FOTOS DE LOS PRODUCTOS
Astro NO sirve las imágenes de src/assets por su ruta directa: hay
que importarlas para que las optimice y les dé una URL válida en
producción. Aquí importamos TODAS las imágenes de src/assets de una
vez y las repartimos por producto según su nombre de archivo.

CÓMO NOMBRAR TUS ARCHIVOS (y no tocar nada más):
  · Portada  →  src/assets/PORTADA-<id>.jpg   (ej. PORTADA-cinta.jpg)
  · Fotos    →  src/assets/fotos-productos/<id>-1.jpg, <id>-2.jpg…
                (ej. cinta-1.jpg, cinta-2.jpg, cinta-3.jpg)
  <id> es el identificador del producto en tienda.js:
  cinta · cojin · arras · abanico
También vale meterlas en subcarpeta por producto
(fotos-productos/cinta/1.jpg) o una carpeta portadas/cinta.jpg.
================================================================ */
const IMAGENES = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/**/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}",
  { eager: true }
);

const sinAcentos = (s: string) => s.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
const archivoDe  = (ruta: string) => ruta.split("/").pop() ?? "";
const numeroDe   = (nombre: string) => { const m = nombre.match(/(\d+)(?=\.[^.]+$)/); return m ? parseInt(m[1], 10) : 0; };

const CATALOGO = Object.entries(IMAGENES).map(([ruta, mod]) => {
  const rutaNorm = sinAcentos(ruta);
  return {
    rutaNorm,
    archivo:   archivoDe(ruta),
    src:       mod.default.src,
    esPortada: /portada/.test(rutaNorm),
    esFoto:    /fotos-?productos/.test(rutaNorm),
  };
});

function resolverFotos(p: (typeof PRODUCTOS)[number]) {
  const idNorm = sinAcentos(p.id);
  const portada = CATALOGO.find((e) => e.esPortada && e.rutaNorm.includes(idNorm));
  const fotos = CATALOGO
    .filter((e) => e.esFoto && !e.esPortada && e.rutaNorm.includes(idNorm))
    .sort((a, b) => numeroDe(a.archivo) - numeroDe(b.archivo))
    .map((e) => e.src);
  return { ...p, portadaSrc: portada ? portada.src : null, fotos };
}

const PRODUCTOS_WEB = PRODUCTOS.map(resolverFotos);

/* Si el nombre contiene "Azahar", esa palabra va en dorado (diseño original) */
const partes = TIENDA.nombre.includes("Azahar") ? TIENDA.nombre.split("Azahar") : null;
const descripcion =
  `Accesorios de boda personalizados y bordados a mano: ${PRODUCTOS.map(p => p.pestana.toLowerCase()).join(", ")}.`;
---

<BaseLayout title={`${TIENDA.nombre} · ${TIENDA.lema}`} description={descripcion}>

<div class="aviso">{TIENDA.anuncio}</div>

<header class="cabecera">
<div>
	<div class="marca">
		{partes ? <>{partes[0]}<span class="azahar">Azahar</span>{partes[1]}</> : TIENDA.nombre}
	</div>
	<p class="lema">{TIENDA.lema}</p>
</div>
<a class="enlace-contacto" href="#contacto">Contacto</a>
</header>

<nav class="pestanas" id="pestanas" role="tablist" aria-label="Productos"></nav>

<main>
<section class="producto" id="producto"></section>
<section class="info" id="info"></section>
</main>

<footer id="contacto">
<div class="pie-int">
	<div>
	<h3>{TIENDA.nombre}</h3>
	<p>Accesorios de boda personalizados, bordados a mano y bajo pedido en Córdoba.</p>
	</div>
	<div>
	<h3>Escríbenos</h3>
	<ul>
		<li><a href={`mailto:${TIENDA.email}`}>{TIENDA.email}</a></li>
		{TIENDA.whatsapp && <li><a href={`https://wa.me/${TIENDA.whatsapp}`}>WhatsApp</a></li>}
	</ul>
	</div>
	<div>
	<h3>Síguenos</h3>
	<ul>
		<li><a href={`https://instagram.com/${TIENDA.instagram.replace("@","")}`} target="_blank" rel="noopener">{TIENDA.instagram}</a></li>
	</ul>
	</div>
</div>
<p class="legal">{TIENDA.legal}</p>
</footer>

<script is:inline define:vars={{ TIENDA, HILOS, PRODUCTOS: PRODUCTOS_WEB }}>
/* ================================================================
A PARTIR DE AQUÍ ES EL MOTOR DE LA WEB
(normalmente no hace falta tocarlo)
================================================================ */

const eur = n => n.toLocaleString('es-ES', { style:'currency', currency:'EUR' });
const esc = s => String(s).replace(/[&<>"']/g, c => (
{'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]
));

/* ---- estado de las elecciones (uno por producto) ---- */
const estado = {};
for (const p of PRODUCTOS){
const primeraVista = p.portadaSrc ? 'portada'
					: (p.fotos && p.fotos.length) ? 'foto-0'
					: 'preview';
estado[p.id] = { sel:{}, txt:{}, extras:{}, nota:'', cantidad:1, vista:primeraVista };
for (const o of (p.opciones||[])){
	if (o.tipo === 'texto') estado[p.id].txt[o.id] = '';
	else estado[p.id].sel[o.id] = o.defecto ?? o.valores[0].id;
}
}
let productoActivo = PRODUCTOS[0].id;

/* ---- utilidades de datos ---- */
const producto = () => PRODUCTOS.find(p => p.id === productoActivo);
const st = () => estado[productoActivo];

function precioUnidad(p, s){
let total = p.precioBase;
for (const o of (p.opciones||[])){
	if (o.tipo === 'texto') continue;
	const v = o.valores.find(v => v.id === s.sel[o.id]);
	if (v && v.precio) total += v.precio;
}
for (const e of (p.extras||[])) if (s.extras[e.id]) total += e.precio;
return total;
}

function valorLegible(p, s, o){
if (o.tipo === 'texto') return s.txt[o.id] || '—';
const v = o.valores.find(v => v.id === s.sel[o.id]);
return v ? (v.nombre + (v.detalle ? ` (${v.detalle})` : '')) : '—';
}

function resumenPedido(){
const p = producto(), s = st();
const lineas = [`Pedido · ${p.nombre}`];
for (const o of (p.opciones||[])) lineas.push(`· ${o.etiqueta}: ${valorLegible(p,s,o)}`);
const ex = (p.extras||[]).filter(e => s.extras[e.id]).map(e => e.nombre);
lineas.push(`· Extras: ${ex.length ? ex.join(', ') : 'ninguno'}`);
lineas.push(`· Cantidad: ${s.cantidad}`);
if (s.nota.trim()) lineas.push(`· Nota: ${s.nota.trim()}`);
lineas.push(`Total estimado: ${eur(precioUnidad(p,s)*s.cantidad)} (IVA incluido)`);
return lineas.join('\n');
}

/* ================================================================
VISTA PREVIA · SVG
================================================================ */

function svgCinta(){
const p = producto(), s = st();
const hilo   = HILOS.find(h => h.id === s.sel.hilo) || HILOS[0];
const larga  = s.sel.largo === 'larga';
const extremo= s.sel.posicion === 'extremo';
const ini    = (s.txt.iniciales || '').trim() || 'M & J';
const fecha  = (s.txt.fecha || '').trim() || '12 · 09 · 2026';
const conFecha = !!s.extras.fechaBordada;
const puntilla = !!s.extras.puntilla;

const xI = 140, xD = 220;             // bordes de la cinta
const topTail = 78;                   // arranque bajo el nudo
const yFin = larga ? 496 : 428;       // largo de la caída
const cyI = extremo ? yFin - 140
					: (topTail + yFin)/2 - (conFecha ? 26 : 10);
const fs  = ini.length > 9 ? 30 : 40; // tamaño de las iniciales

/* puntilla: bolitas sobre ambos bordes */
let bolitas = '';
if (puntilla){
	for (let y = topTail + 12; y < yFin - 26; y += 13){
	bolitas += `<circle cx="${xI}" cy="${y}" r="4.4" fill="#FBF6EC" stroke="#E0D2BA" stroke-width="1"/>`;
	bolitas += `<circle cx="${xD}" cy="${y}" r="4.4" fill="#FBF6EC" stroke="#E0D2BA" stroke-width="1"/>`;
	}
}

/* florecitas fijas (siempre los mismos tonos) */
const flor = (cx, cy, r) => {
	let s = '';
	for (let k = 0; k < 5; k++){
	const a = k * 2*Math.PI/5 - Math.PI/2;
	s += `<circle cx="${(cx + Math.cos(a)*r*1.6).toFixed(1)}" cy="${(cy + Math.sin(a)*r*1.6).toFixed(1)}" r="${r}" fill="#DDBFAE"/>`;
	}
	return s + `<circle cx="${cx}" cy="${cy}" r="${(r*0.8).toFixed(1)}" fill="#A9B39B"/>`;
};

const colaExtra = larga
	? `<path d="M198 ${topTail} L252 ${topTail} L252 ${yFin-70} L225 ${yFin-88} L198 ${yFin-70} Z"
			transform="rotate(3 225 ${topTail})"
			fill="#F3ECDD" stroke="#E6DAC4" stroke-width="1" opacity="0.75"/>`
	: '';

const fechaTxt = conFecha
	? `<text transform="translate(158 ${cyI}) rotate(90)" text-anchor="middle"
			font-family="Jost, sans-serif" font-size="12" letter-spacing="3"
			fill="${hilo.color}">${esc(fecha)}</text>`
	: '';

return `
<svg viewBox="0 0 360 540" xmlns="http://www.w3.org/2000/svg" role="img"
	aria-label="Vista previa de la cinta del ramo con iniciales ${esc(ini)}">
	<!-- tallos del ramo -->
	<g stroke="#7A8471" stroke-width="2" stroke-linecap="round" fill="none">
	<path d="M166 14 L176 46"/><path d="M180 8 L180 46"/><path d="M194 14 L184 46"/>
	</g>
	<circle cx="163" cy="12" r="5" fill="#DDBFAE"/>
	<circle cx="180" cy="6"  r="5" fill="#E7CBB9"/>
	<circle cx="197" cy="12" r="5" fill="#DDBFAE"/>

	${colaExtra}

	<!-- caída principal -->
	<path d="M${xI} ${topTail} L${xD} ${topTail} L${xD} ${yFin} L180 ${yFin-24} L${xI} ${yFin} Z"
		fill="#FAF4E8" stroke="#E6DAC4" stroke-width="1"/>

	<!-- lazada -->
	<path d="M178 66 C110 34 96 88 172 78 Z" fill="#F6EFE0" stroke="#E6DAC4" stroke-width="1"/>
	<path d="M182 66 C250 34 264 88 188 78 Z" fill="#F6EFE0" stroke="#E6DAC4" stroke-width="1"/>
	<rect x="162" y="56" width="36" height="26" rx="8" fill="#F8F2E6" stroke="#E6DAC4" stroke-width="1"/>

	${bolitas}

	<!-- pespuntes laterales en el color del hilo -->
	<g stroke="${hilo.color}" stroke-width="1.4" stroke-linecap="round"
	stroke-dasharray="1.5 5.5" opacity="0.5">
	<path d="M${xI+6} ${topTail+14} L${xI+6} ${yFin-30}"/>
	<path d="M${xD-6} ${topTail+14} L${xD-6} ${yFin-30}"/>
	</g>

	<!-- florecitas del diseño (fijas) -->
	${flor(180, topTail+26, 3.4)}
	${flor(163, topTail+38, 2.6)}
	${flor(197, topTail+38, 2.6)}

	<!-- iniciales bordadas -->
	<text transform="translate(190 ${cyI}) rotate(90)" text-anchor="middle"
		font-family="'Pinyon Script', cursive" font-size="${fs}"
		fill="${hilo.color}">${esc(ini)}</text>
	${fechaTxt}
</svg>`;
}

/* iconos sencillos para los productos en borrador */
function svgBoceto(tipo){
const trazos = {
	cojin: `<rect x="70" y="86" width="120" height="96" rx="26"/>
			<path d="M70 110 Q130 96 190 110 M70 158 Q130 172 190 158"/>
			<circle cx="118" cy="134" r="13"/><circle cx="140" cy="134" r="13"/>`,
	bolsa: `<path d="M96 96 C96 78 164 78 164 96 L176 108 C204 150 192 190 130 190 C68 190 56 150 84 108 Z"/>
			<path d="M92 106 L168 106"/>
			<path d="M118 96 C118 84 142 84 142 96" stroke-dasharray="3 5"/>`,
	abanico:`<path d="M130 186 L58 96 M130 186 L98 78 M130 186 L130 70 M130 186 L162 78 M130 186 L202 96"/>
			<path d="M58 96 C90 62 170 62 202 96"/>
			<circle cx="130" cy="186" r="6"/>`
};
return `
<svg viewBox="0 0 260 240" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Boceto del producto">
	<circle cx="130" cy="128" r="102" fill="#EFE6D6"/>
	<g fill="none" stroke="#5C554A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
	${trazos[tipo] || trazos.cojin}
	</g>
</svg>`;
}

/* ================================================================
PINTADO DE LA PÁGINA
================================================================ */

function pintarPestanas(){
const nav = document.getElementById('pestanas');
nav.innerHTML = PRODUCTOS.map(p => `
	<button role="tab" data-prod="${p.id}"
			aria-selected="${p.id === productoActivo}">${esc(p.pestana)}</button>
`).join('');
nav.querySelectorAll('button').forEach(b =>
	b.addEventListener('click', () => {
	productoActivo = b.dataset.prod;
	pintarPestanas(); pintarProducto(); pintarInfo();
	window.scrollTo({ top: 0, behavior: 'smooth' });
	})
);
}

function htmlOpciones(p, s){
return (p.opciones||[]).map(o => {
	if (o.tipo === 'texto'){
	return `
	<div class="grupo campo">
		<div class="grupo-cabecera"><label for="txt-${o.id}">${esc(o.etiqueta)}</label></div>
		<input type="text" id="txt-${o.id}" data-txt="${o.id}"
			maxlength="${o.max||30}" placeholder="${esc(o.placeholder||'')}"
			value="${esc(s.txt[o.id])}">
		${o.ayuda ? `<p class="ayuda">${esc(o.ayuda)}</p>` : ''}
	</div>`;
	}
	if (o.tipo === 'muestras'){
	return `
	<div class="grupo">
		<div class="grupo-cabecera">
		<span class="titulo">${esc(o.etiqueta)}</span>
		<span class="valor" data-etq="${o.id}"></span>
		</div>
		<div class="muestras" role="radiogroup" aria-label="${esc(o.etiqueta)}">
		${o.valores.map(v => `
			<label style="background:${v.color}" title="${esc(v.nombre)}">
			<input type="radio" name="op-${o.id}" value="${v.id}" data-op="${o.id}"
					${s.sel[o.id]===v.id?'checked':''} aria-label="${esc(v.nombre)}">
			</label>`).join('')}
		</div>
	</div>`;
	}
	/* tipo 'botones' */
	return `
	<div class="grupo">
	<div class="grupo-cabecera"><span class="titulo">${esc(o.etiqueta)}</span></div>
	<div class="botones" role="radiogroup" aria-label="${esc(o.etiqueta)}">
		${o.valores.map(v => `
		<label>
			<input type="radio" name="op-${o.id}" value="${v.id}" data-op="${o.id}"
				${s.sel[o.id]===v.id?'checked':''}>
			${esc(v.nombre)}
			${v.detalle ? `<small>${esc(v.detalle)}</small>` : ''}
			${v.precio  ? `<small>+${eur(v.precio)}</small>` : ''}
		</label>`).join('')}
	</div>
	</div>`;
}).join('');
}

/* Lista ordenada de vistas de la galería:
   portada · fotos reales · diagrama del bordado (color de hilo en vivo).
   Si aún no hay fotos, deja huecos indicativos + el diagrama. */
function vistasDe(p){
const v = [];
if (p.portadaSrc) v.push({ id:'portada', etiqueta:'Portada', tipo:'img', src:p.portadaSrc });
(p.fotos||[]).forEach((src,i) => v.push({ id:'foto-'+i, etiqueta:'Foto '+(i+1), tipo:'img', src }));
const hayFotos = v.length > 0;
v.push({ id:'preview', etiqueta:'Bordado', tipo:'preview' });   // ← el diagrama que cambia con el hilo
if (!hayFotos) [1,2,3].forEach(i => v.push({ id:'hueco-'+i, etiqueta:'Foto '+i, tipo:'hueco' }));
return v;
}

function pintarProducto(){
const p = producto(), s = st();
const cont = document.getElementById('producto');

const miniIcono = `<svg viewBox="0 0 34 34" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M6 24 C14 10 22 10 28 22"/><circle cx="24" cy="9" r="3.4"/><path d="M9 27 h16"/></svg>`;
const contenidoMini = v => {
	if (v.tipo === 'img')     return `<img src="${v.src}" alt="" loading="lazy">`;
	if (v.tipo === 'preview') return `<span class="mini-svg">${p.id==='cinta' ? svgCinta() : svgBoceto(p.icono)}</span>`;
	return `<span class="mini-hueco">${miniIcono}</span>`;
};
const miniaturas = vistasDe(p).map(v =>
	`<button class="mini mini-${v.tipo}" data-vista="${v.id}" title="${esc(v.etiqueta)}"
			aria-label="${esc(v.etiqueta)}" aria-current="${s.vista===v.id}">${contenidoMini(v)}</button>`
).join('');

cont.innerHTML = `
	<div class="galeria">
	<div class="principal" id="lienzo"></div>
	<p class="pie-preview" id="pie-lienzo"></p>
	<div class="miniaturas" id="miniaturas">${miniaturas}</div>
	</div>

	<div class="config">
	<p class="miga">Bodas · ${esc(p.pestana)}</p>
	<h2>${esc(p.nombre)}${p.borrador ? '<span class="chip-borrador">Borrador</span>' : ''}</h2>
	<p class="precio-desde">Desde ${eur(p.precioBase)}<small>IVA incluido</small></p>
	<div class="descripcion">${p.descripcion.map(t => `<p>${esc(t)}</p>`).join('')}</div>

	${htmlOpciones(p, s)}

	${(p.extras && p.extras.length) ? `
	<div class="grupo extras">
		<div class="grupo-cabecera"><span class="titulo">Extras</span></div>
		${p.extras.map(e => `
		<label>
			<input type="checkbox" data-extra="${e.id}" ${s.extras[e.id]?'checked':''}>
			${esc(e.nombre)}
			<span class="mas">+${eur(e.precio)}</span>
		</label>`).join('')}
	</div>` : ''}

	<div class="grupo campo">
		<div class="grupo-cabecera"><label for="nota">Nota del pedido</label></div>
		<textarea id="nota" placeholder="Cuéntanos cualquier detalle que debamos saber.">${esc(s.nota)}</textarea>
	</div>

	<div class="linea-total">
		<p class="total" id="total"></p>
		<div class="cantidad" aria-label="Cantidad">
		<button type="button" data-delta="-1" aria-label="Quitar una unidad">−</button>
		<output id="cantidad">${s.cantidad}</output>
		<button type="button" data-delta="1" aria-label="Añadir una unidad">+</button>
		</div>
	</div>

	<div class="acciones">
		<button class="btn-principal" id="btn-solicitar"></button>
		<button class="btn-secundario" id="btn-copiar">Copiar resumen del diseño</button>
		<p class="nota-plazo">Elaboración: 15 días laborables · Envío en 48 h</p>
	</div>
	</div>
`;

/* --- listeners --- */
cont.querySelectorAll('[data-op]').forEach(el =>
	el.addEventListener('change', () => { s.sel[el.dataset.op] = el.value; refrescar(); }));

cont.querySelectorAll('[data-txt]').forEach(el =>
	el.addEventListener('input', () => { s.txt[el.dataset.txt] = el.value; refrescar(); }));

cont.querySelectorAll('[data-extra]').forEach(el =>
	el.addEventListener('change', () => { s.extras[el.dataset.extra] = el.checked; refrescar(); }));

cont.querySelector('#nota').addEventListener('input', e => { s.nota = e.target.value; });

cont.querySelectorAll('[data-delta]').forEach(el =>
	el.addEventListener('click', () => {
	s.cantidad = Math.max(1, s.cantidad + Number(el.dataset.delta));
	document.getElementById('cantidad').textContent = s.cantidad;
	refrescar();
	}));

cont.querySelectorAll('#miniaturas button').forEach(el =>
	el.addEventListener('click', () => {
	s.vista = el.dataset.vista;
	cont.querySelectorAll('#miniaturas button')
		.forEach(b => b.setAttribute('aria-current', b === el));
	refrescar();
	}));

cont.querySelector('#btn-solicitar').addEventListener('click', () => {
	const texto = resumenPedido();
	if (TIENDA.whatsapp){
	window.open(`https://wa.me/${TIENDA.whatsapp}?text=${encodeURIComponent(texto)}`, '_blank');
	} else {
	const asunto = `Pedido · ${producto().nombre}`;
	window.location.href =
		`mailto:${TIENDA.email}?subject=${encodeURIComponent(asunto)}&body=${encodeURIComponent(texto)}`;
	}
});

cont.querySelector('#btn-copiar').addEventListener('click', async e => {
	try{
	await navigator.clipboard.writeText(resumenPedido());
	e.target.textContent = 'Resumen copiado ✓';
	setTimeout(() => e.target.textContent = 'Copiar resumen del diseño', 1800);
	}catch(_){
	alert(resumenPedido());
	}
});

refrescar();
}

/* actualiza vista previa, etiquetas y total sin repintar los campos */
function refrescar(){
const p = producto(), s = st();

/* lienzo principal */
const lienzo = document.getElementById('lienzo');
const pie = document.getElementById('pie-lienzo');
if (s.vista === 'preview'){
	lienzo.innerHTML = (p.id === 'cinta') ? svgCinta() : svgBoceto(p.icono);
	pie.textContent = (p.id === 'cinta')
	? 'Diagrama del bordado · cambia con el color del hilo'
	: 'Boceto · las fotos reales irán aquí';
} else if (s.vista === 'portada'){
	lienzo.innerHTML = `<img src="${p.portadaSrc}" alt="${esc(p.nombre)}" style="border-radius:10px">`;
	pie.textContent = '';
} else if (s.vista.startsWith('foto-')){
	const f = p.fotos[Number(s.vista.split('-')[1])];
	lienzo.innerHTML = `<img src="${f}" alt="${esc(p.nombre)}" style="border-radius:10px">`;
	pie.textContent = '';
} else {
	lienzo.innerHTML = `
	<div class="hueco-foto">
		<svg width="34" height="34" viewBox="0 0 34 34" fill="none"
			stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
		<path d="M6 24 C14 10 22 10 28 22"/><circle cx="24" cy="9" r="3.4"/>
		<path d="M9 27 h16"/>
		</svg>
		<span>Sube tus fotos y las colocamos aquí,<br>con la máxima calidad posible.</span>
	</div>`;
	pie.textContent = '';
}

/* la miniatura del bordado sigue el color de hilo elegido */
const miniPrev = document.querySelector('#miniaturas .mini-preview .mini-svg');
if (miniPrev) miniPrev.innerHTML = (p.id === 'cinta') ? svgCinta() : svgBoceto(p.icono);

/* nombre del color de hilo elegido */
(p.opciones||[]).filter(o => o.tipo === 'muestras').forEach(o => {
	const v = o.valores.find(v => v.id === s.sel[o.id]);
	const etq = document.querySelector(`[data-etq="${o.id}"]`);
	if (etq) etq.textContent = v ? v.nombre : '';
});

/* total */
document.getElementById('total').innerHTML =
	`${eur(precioUnidad(p,s) * s.cantidad)}<small>IVA incluido</small>`;

/* texto del botón principal */
document.getElementById('btn-solicitar').textContent =
	TIENDA.whatsapp ? 'Solicitar por WhatsApp' : 'Solicitar por email';
}

/* pestañas de información (Más info / Plazos / Devoluciones) */
function pintarInfo(){
const p = producto();
const claves = Object.keys(p.info || {});
const cont = document.getElementById('info');
if (!claves.length){ cont.innerHTML = ''; return; }

const md = t => esc(t)
	.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
	.split('\n').map(l => `<p>${l}</p>`).join('');

cont.innerHTML = `
	<div class="info-tabs" role="tablist" aria-label="Información del producto">
	${claves.map((c,i) => `<button role="tab" data-i="${i}" aria-selected="${i===0}">${esc(c)}</button>`).join('')}
	</div>
	${claves.map((c,i) => `<div class="info-panel" data-panel="${i}" ${i?'hidden':''}>${md(p.info[c])}</div>`).join('')}
`;
cont.querySelectorAll('[role=tab]').forEach(b =>
	b.addEventListener('click', () => {
	cont.querySelectorAll('[role=tab]').forEach(x => x.setAttribute('aria-selected', x===b));
	cont.querySelectorAll('[data-panel]').forEach(pan =>
		pan.hidden = pan.dataset.panel !== b.dataset.i);
	}));
}

pintarPestanas();
pintarProducto();
pintarInfo();
</script>

</BaseLayout>